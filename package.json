{
  "name": "walletservice",
  "version": "1.0.0",
  "description": "a demo wallet service for lendsqr",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bootstrap": "npm install && npm run init",
    "init": "node scripts/init-project.mjs",
    "env:init": "node scripts/init-project.mjs --env-only",
    "dev": "npx nodemon src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "db:check": "tsx src/scripts/check-db.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "knex": "^3.1.0",
    "mysql2": "^3.11.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.29",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
